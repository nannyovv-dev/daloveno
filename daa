            { name: "นาโน", text: "“เจ็บสิโว้ย!!! ถามอะไรโง่ๆ!”", action: "normal" },
            { name: "องครักษ์/ผู้ติดตาม", text: "“บังอาจ! เจ้ากล้าหมิ่นประมาทท่านองค์รักทายาทได้ยังไง!!!”", action: "sword_sound" },
            { name: "ดาเรียน", text: "“มิเป็นอันใดหรอก…เขาก็แค่ผู้ที่บังเอิญมาชนข้าก็เท่านั้น ข้ามิถือสาอันใด“", action: "normal" },
            { name: "ดาเรียน", text: "“ลุกขึ้นมาสิ…จับมือข้าเอาไว้ก็ย่อมได้…”", action: "normal" },
            { name: "นาโน", text: "“ขอบใจ! แต่ทีหลังไม่ต้อง!”", action: "show_illust" },
            { name: "ดาเรียน", text: "”เดี๋ยวสิ… กลิ่นอายของเจ้า...มิเหมือนคนที่อยู่ในเขตอาณาจักรของเราเลย เจ้าเป็นผู้ใดกัน?“", action: "normal" },
            { name: "นาโน", text: "”ฉันขอตัว!“", action: "grab_sound" },
            { name: "ดาเรียน", text: "“ข้าบอกว่าเดี๋ยวไง!”", action: "normal" },
            { name: "นาโน", text: "“เฮ้ย! ปล่อยนะโว้ยยยยยย!”", action: "normal" },
            
            // --- เพิ่มรายละเอียดบทสนทนาใหม่ตามคำขอ ---
            { name: "ดาเรียน", text: "“ช่วย…ไปเต้นรำกับข้าในคืนก่อนที่ข้าครองราชย์ได้หรือไม่ เป็นวันที่ฉลอง… ‘วันเกิด‘ ครบ 20 ปีของข้า ในงานเลี้ยงของราชวงศ์ ช่วยมาเป็นคู่ให้ข้าทีได้ไหม?”", action: "normal" },
            { name: "องครักษ์/ผู้ติดตาม", text: "“องค์รัชทายาท! มิได้นะพ่ะย่ะค่ะ!“", action: "normal" },
            { name: "ดาเรียน", text: "”อย่าคิดจะขัดคำสั่งข้า… จงเงียบเสีย และเจ้าก็จงตอบข้า…“", action: "normal" },
            { name: "นาโน", text: "“นายบ้าไปแล้วรึไง! ฉันเนี่ยนะจะยอมเต้นรำกับนาย!…“", action: "normal" },
            { name: "", text: "(ก่อนที่ความวุ่นวายจะบานปลายไปมากกว่านี้ ทันใดนั้นก็พลันเกิดแสงสว่างวูบจ้าขึ้นมาปกคลุมทั่วทั้งโสตประสาท...)", action: "flash_ending" }
        ];

        let currentLine = 0;
        const speakerName = document.getElementById('speakerName');
        const dialogueText = document.getElementById('dialogueText');
