        // เริ่มฉากเกมคัทซีนและเล่นเสียงฝีเท้า
        function startNovelGame() {
            document.getElementById('profileScreen').classList.remove('active');
            document.getElementById('gamePlayScreen').classList.add('active');
            document.getElementById('sunlight').classList.add('shine');
            
            // ซ่อนกล่องข้อความไว้ก่อนเพื่อเล่นเสียงฝีเท้า ตึก ตึก...
            const dialogueBox = document.querySelector('.dialogue-box');
            dialogueBox.style.pointerEvents = 'none'; 
            dialogueBox.style.opacity = '0';

            if (!isMuted) {
                sfxBirds.volume = 0.3;
                sfxBirds.play().catch(()=>{});

                // เสียงฝีเท้าก้าวแรก: "ตึก"
                setTimeout(() => {
                    sfxFootstep.currentTime = 0; sfxFootstep.volume = 0.8;
                    sfxFootstep.play().catch(()=>{});
                }, 600);

                // เสียงฝีเท้าก้าวที่สอง: "...ตึก"
                setTimeout(() => {
                    sfxFootstep.currentTime = 0; sfxFootstep.volume = 0.8;
                    sfxFootstep.play().catch(()=>{});
                }, 1400);
            }

            // หลังจากจบฝีเท้า 2 วินาที แสดงหน้าต่างคุยและมีเสียงคำว่า "โอ๊ย!"
            setTimeout(() => {
                dialogueBox.style.pointerEvents = 'auto';
                dialogueBox.style.opacity = '1';
                showDialogue();
            }, 2200);
        }

        function showDialogue() {
            if (currentLine >= dialogueData.length) return;

            const current = dialogueData[currentLine];
            speakerName.innerText = current.name;
            dialogueText.innerText = current.text;

            if(!isMuted) {
                switch(current.action) {
                    case "sword_sound":
                        sfxSword.currentTime = 0; sfxSword.volume = 0.8; sfxSword.play().catch(()=>{});
                        break;
                    case "show_illust":
                        novelIllust.classList.add('fade-in');
                        break;
                    case "grab_sound":
                        sfxGrab.currentTime = 0; sfxGrab.volume = 0.6; sfxGrab.play().catch(()=>{});
                        break;
                    case "flash_ending":
                        triggerEndingTransition();
                        break;
                }
            } else {
                if (current.action === "show_illust") {
                    novelIllust.classList.add('fade-in');
                } else if (current.action === "flash_ending") {
                    triggerEndingTransition();
                }
            }
        }

        function nextDialogue() {
            currentLine++;
            showDialogue();
        }

        // ==================== 🎬 เอฟเฟกต์ฉากจบความฝันเต้นรำอุ่นๆ ====================
        function triggerEndingTransition() {
            const flash = document.getElementById('whiteFlash');
            
            // เล่นเสียงวาบแสงจ้า
            flash.classList.add('active');
            
            setTimeout(() => {
                // ปิดฉากนิยายและเปิดหน้าจอฉากจบเต้นรำ
                document.getElementById('gamePlayScreen').classList.remove('active');
                document.getElementById('endingScreen').classList.add('active');
                
                // ค่อยๆ ลดเสียง BGM แรก และเริ่มเปิดเพลงเต้นรำใหม่ของคุณ
                if (!isMuted) {
                    bgm.pause();
                    bgmWaltz.volume = 0;
                    bgmWaltz.play().catch(()=>{});
                    
                    // 🌟 ปรับให้เฟดเสียงเพลงใหม่ขึ้นมาดังเต็มอิ่มมากยิ่งขึ้น (ลิมิตความดังไว้ที่ 0.8 ตามคำขอ)
                    let vol = 0;
                    const fadeUp = setInterval(() => {
                        vol += 0.05;
                        if (vol >= 0.8) {
                            bgmWaltz.volume = 0.8;
                            clearInterval(fadeUp);
                        } else {
                            bgmWaltz.volume = vol;
                        }
                    }, 100);
                }

                // สลายเอฟเฟกต์แสงวาบ
                flash.classList.remove('active');
                flash.style.opacity = '1';
                setTimeout(() => { flash.style.opacity = '0'; }, 50);

                // สร้างละอองฝุ่นทองพริ้วไหว
                createEndingDust();
            }, 600);
        }

        function createEndingDust() {
            const sparklesContainer = document.getElementById('endingSparkles');
            sparklesContainer.innerHTML = '';
            for(let i = 0; i < 25; i++) {
                const dust = document.createElement('div');
                dust.classList.add('dust-particle');
                dust.style.left = Math.random() * 100 + '%';
                dust.style.top = Math.random() * 100 + '%';
                const size = Math.random() * 4 + 2;
                dust.style.width = size + 'px';
                dust.style.height = size + 'px';
                dust.style.animationDuration = (Math.random() * 4 + 4) + 's';
                dust.style.animationDelay = (Math.random() * 3) + 's';
                sparklesContainer.appendChild(dust);
            }
        }

        function resetToTitle() {
            document.getElementById('gamePlayScreen').classList.remove('active');
            document.getElementById('profileScreen').classList.remove('active');
            document.getElementById('endingScreen').classList.remove('active');
            novelIllust.classList.remove('fade-in');
            currentLine = 0;
            
            // หยุดเพลงวอลทซ์สลับมาเล่น BGM ปกติ
            bgmWaltz.pause();
            if(!isMuted) {
                bgm.currentTime = 0;
                bgm.volume = 0.3;
                bgm.play().catch(()=>{});
            }

            document.getElementById('progressBar').style.width = '0%';
            document.getElementById('progressText').innerText = '0%';
            
            const mainScreen = document.getElementById('mainScreen');
            mainScreen.style.opacity = '1';
        }

        // ==================== ระบบทำงานทั่วไป ====================
        function startDownload() {
            startBGM();
            const mainScreen = document.getElementById('mainScreen');
            const downloadScreen = document.getElementById('downloadScreen');
            const progressBar = document.getElementById('progressBar');
            const progressText = document.getElementById('progressText');

            mainScreen.style.opacity = '0';
            setTimeout(() => {
                downloadScreen.classList.add('active');
                
                let progress = 0;
                const interval = setInterval(() => {
                    progress += 4;
                    progressBar.style.width = progress + '%';
                    progressText.innerText = progress + '%';

                    if (progress >= 100) {
                        clearInterval(interval);
                        setTimeout(() => {
                            downloadScreen.classList.remove('active');
                            document.getElementById('storyScreen').classList.add('active');
                        }, 500);
                    }
                }, 40);
            }, 800);
        }

        function showCharacterProfile() {
            document.getElementById('storyScreen').classList.remove('active');
            document.getElementById('profileScreen').classList.add('active');
        }

        function showInstructions() {
            startBGM();
            const overlayLayer = document.getElementById('overlayLayer');
            const countdownBox = document.getElementById('countdownBox');
            const infoBox = document.getElementById('infoBox');
            const closeBtn = document.getElementById('closeBtn');

            overlayLayer.classList.add('active');
            countdownBox.style.display = 'block';
            
            let count = 3;
            countdownBox.innerText = count;

            const countdownInterval = setInterval(() => {
                count--;
                if (count > 0) {
                    countdownBox.innerText = count;
                } else {
                    clearInterval(countdownInterval);
                    countdownBox.style.display = 'none';
                    infoBox.style.display = 'block';
                    setTimeout(() => { infoBox.classList.add('float-up'); }, 50);
                    setTimeout(() => { closeBtn.style.opacity = '1'; }, 1200);
                }
            }, 1000);
        }

        function closeInstructions() {
            const overlayLayer = document.getElementById('overlayLayer');
            const infoBox = document.getElementById('infoBox');
            const closeBtn = document.getElementById('closeBtn');

            infoBox.classList.remove('float-up');
            closeBtn.style.opacity = '0';
            
            setTimeout(() => {
                overlayLayer.classList.remove('active');
                infoBox.style.display = 'none';
            }, 800);
        }
    </script>
</body>
</html>
