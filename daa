    <audio id="bgmWaltz" src="https://familiar-lavender-e0lgqpyo.edgeone.dev/v1c044g50000d7jhrjvog65h2ppnk290.mp3" loop preload="auto"></audio>

    <script>
        // ==================== 🔊 ระบบจัดการเสียงเกมสังเคราะห์ (Web Audio API) ====================
        let isMuted = false;
        let audioCtx = null;

        // ฟังก์ชันเริ่มใช้งาน AudioContext (เพื่อหลีกเลี่ยงข้อห้ามความปลอดภัยของเบราว์เซอร์)
        function initAudioContext() {
            if (!audioCtx) {
                audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            }
        }

        // 🎵 สร้างเสียงสัมผัสเกม "ตึ๊ก" (สไตล์เกมโบราณแบบแหลมกำลังดี)
        function playTukSound() {
            if (isMuted) return;
            initAudioContext();
            if (audioCtx.state === 'suspended') {
                audioCtx.resume();
            }

            const osc = audioCtx.createOscillator();
            const gainNode = audioCtx.createGain();

            osc.connect(gainNode);
            gainNode.connect(audioCtx.destination);

            // เซ็ตชนิดคลื่นเสียงเป็นแบบ Triangle (ให้ความรู้สึกนุ่มแต่คมแหลมคล้ายยุคเรโทร)
            osc.type = 'triangle';

            // ความถี่แหลมกำลังดี (สไลด์จากความถี่ 800Hz ลงมา 250Hz อย่างเร็วมากเพื่อสร้างมิติเสียง ตึ๊ก)
            osc.frequency.setValueAtTime(800, audioCtx.currentTime);
            osc.frequency.exponentialRampToValueAtTime(250, audioCtx.currentTime + 0.08);

            // ความดังสั้นกระชับ
            gainNode.gain.setValueAtTime(0.25, audioCtx.currentTime);
            gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.08);

            osc.start();
            osc.stop(audioCtx.currentTime + 0.08);
        }

        const bgm = document.getElementById('bgmCinematic');
        const bgmWaltz = document.getElementById('bgmWaltz');
        const sfxClick = document.getElementById('sfxClick');
        const sfxFootstep = document.getElementById('sfxFootstep');
        const sfxBirds = document.getElementById('sfxBirds');
        const sfxSword = document.getElementById('sfxSword');
        const sfxGrab = document.getElementById('sfxGrab');

        // เริ่มเล่น BGM
        function startBGM() {
            if (!isMuted) {
                bgm.volume = 0.3;
                bgmWaltz.pause();
                bgm.play().catch(()=>{});
            }
        }

        // เล่นเสียงเมื่อปุ่มโดนคลิก
        function playClickSound() {
            playTukSound(); // ส่งเสียงตึ๊กแหลมด้วยเสมอ
            if (!isMuted) {
                sfxClick.currentTime = 0;
                sfxClick.volume = 0.3;
                sfxClick.play().catch(()=>{});
            }
        }

        // ปุ่ม เปิด/ปิด เสียง
        function toggleMute(e) {
            e.stopPropagation();
            isMuted = !isMuted;
            
            const icon = document.getElementById('audioIcon');
            const statusText = document.getElementById('audioStatusText');

            if(isMuted) {
                icon.innerText = "🔇";
                statusText.innerText = "SOUND: OFF";
                bgm.pause();
                bgmWaltz.pause();
                sfxBirds.pause(); sfxSword.pause(); sfxGrab.pause(); sfxFootstep.pause();
            } else {
                icon.innerText = "🔊";
                statusText.innerText = "SOUND: ON";
                // เช็คว่าหน้าตอนจบกำลังแสดงอยู่หรือไม่
                if(document.getElementById('endingScreen').classList.contains('active')) {
                    bgmWaltz.play().catch(()=>{});
                } else {
                    bgm.play().catch(()=>{});
                }
            }
            playTukSound();
        }

        // ==================== ✨ เอฟเฟกต์ดวงดาวประกายสีขาวระยิบระยับ ====================
        const container = document.getElementById('container');

        container.addEventListener('click', (e) => {
            // ไม่ว่าคลิกโดนอะไรในจอเกม ก็จะมีเสียง ตึ๊ก ตลอดเวลา
            playTukSound();
            createSparkles(e.clientX, e.clientY);
        });

        // ฟังก์ชันสร้างกลุ่มดาวประกายสีขาว
        function createSparkles(x, y) {
            const rect = container.getBoundingClientRect();
            const clickX = x - rect.left;
            const clickY = y - rect.top;

            // ตัวเลือกสัญลักษณ์ดวงดาววิบวับแบบต่างๆ
            const starSymbols = ['✦', '✧', '★', '☆'];

            for (let i = 0; i < 8; i++) {
                const star = document.createElement('div');
                star.classList.add('sparkle-particle');
                
                // สุ่มสัญลักษณ์ดวงดาวขาว
                star.innerText = starSymbols[Math.floor(Math.random() * starSymbols.length)];
                
                star.style.left = `${clickX}px`;
                star.style.top = `${clickY}px`;
                
                // คำนวณองศาและระยะกระจายของดวงดาว
                const angle = Math.random() * Math.PI * 2;
                const distance = Math.random() * 65 + 25;
                const pX = Math.cos(angle) * distance;
                const pY = Math.sin(angle) * distance;
                
                star.style.setProperty('--x', `${pX}px`);
                star.style.setProperty('--y', `${pY}px`);
                
                // สุ่มขนาดดวงดาวเล็กใหญ่ไม่เท่ากัน
                const randomSize = Math.random() * 12 + 12;
                star.style.fontSize = `${randomSize}px`;
                
                container.appendChild(star);
                setTimeout(() => { star.remove(); }, 800);
            }
        }

        // ==================== 🎬 บทสนทนาในเกมและเอฟเฟกต์เสียง ====================
        const dialogueData = [
            { name: "???", text: "โอ๊ย!", action: "footsteps_pre_scene" },
