<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>THE ETERNAL UNIVERSE</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@300;400;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Sarabun:wght@200;300;400;500;600&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --gold-color: #dfba6b;
            --gold-light: #fcf6ba;
            --gold-dark: #aa771c;
            --gold-gradient: linear-gradient(45deg, #bf953f, #fcf6ba, #b38728, #fbf5b7, #aa771c);
            --royal-black: #050507;
            --dark-gray: #121216;
            --border-gold: 1px solid rgba(191, 149, 63, 0.4);
            --gold-shadow: 0 0 15px rgba(191, 149, 63, 0.2);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            user-select: none;
            -webkit-user-select: none;
        }

        body {
            background-color: #000;
            font-family: 'Cormorant Garamond', 'Sarabun', serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            overflow: hidden;
        }

        /* จำลองหน้าจอเกมแบบยืดหยุ่น */
        .game-container {
            width: 100vw;
            height: 100vh;
            max-width: 900px;
            max-height: 750px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 0 40px rgba(191, 149, 63, 0.35);
            background: var(--royal-black);
            border: 2px solid #bf953f;
            border-image: linear-gradient(to bottom, #bf953f, #000, #bf953f) 1;
        }

        .game-container::before, .game-container::after {
            content: "";
            position: absolute;
            width: 20px;
            height: 20px;
            border: 2px solid var(--gold-color);
            z-index: 100;
            pointer-events: none;
        }
        .game-container::before { top: 10px; left: 10px; border-right: none; border-bottom: none; }
        .game-container::after { bottom: 10px; right: 10px; border-left: none; border-top: none; }

        /* --- ปุ่มควบคุมระบบเสียง (Audio Controller) --- */
        .audio-control-btn {
            position: absolute;
            top: 20px;
            right: 20px;
            z-index: 150;
            background: rgba(0, 0, 0, 0.7);
            border: 1px solid var(--gold-color);
            color: var(--gold-color);
            padding: 8px 12px;
            font-family: 'Cinzel', serif;
            font-size: 0.75rem;
            cursor: pointer;
            letter-spacing: 1px;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .audio-control-btn:hover {
            background: var(--gold-color);
            color: #000;
            box-shadow: 0 0 10px var(--gold-color);
        }

        /* --- หน้าแรก/หน้าปกเกม --- */
        .game-screen {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-end;
            padding: 50px 30px;
            transition: opacity 0.8s ease-in-out, transform 0.8s ease-in-out;
            z-index: 10;
        }

        .bg-image {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background-image: url('https://i.ibb.co/tp0dpwQ2/8070-B2-B7-71-C8-4640-BCBF-552-E2-E188219.png');
            background-size: cover;
            background-position: center top;
            z-index: 1;
            animation: dreamMovement 20s ease-in-out infinite alternate;
        }

        .bg-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(to bottom, rgba(10,10,12,0.1) 0%, rgba(10,10,12,0.4) 40%, rgba(10,10,12,0.95) 90%);
            z-index: 2;
        }

        @keyframes dreamMovement {
            0% { transform: scale(1.0); }
            100% { transform: scale(1.05); }
        }

        .game-header {
            position: relative;
            z-index: 3;
            text-align: center;
            margin-bottom: 25px;
            width: 100%;
        }

        .game-title {
            font-family: 'Cinzel', serif;
            font-size: 2.2rem;
            font-weight: 400;
            letter-spacing: 6px;
            background: var(--gold-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 10px rgba(253, 246, 186, 0.2);
        }

        .menu-buttons {
            position: relative;
            z-index: 3;
            width: 100%;
            max-width: 320px;
            display: flex;
            flex-direction: column;
            gap: 15px;
            margin-bottom: 20px;
        }

        .btn-royal {
            background: #000000;
            color: var(--gold-color);
            border: 1px solid rgba(191, 149, 63, 0.5);
            padding: 13px 0;
            font-family: 'Cinzel', serif;
            font-size: 1rem;
            letter-spacing: 3px;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
            text-transform: uppercase;
            position: relative;
            box-shadow: 0 4px 15px rgba(0,0,0,0.6);
            text-align: center;
        }

        .btn-royal::before {
            content: '';
            position: absolute;
            top: 2px; left: 2px; right: 2px; bottom: 2px;
            border: 1px solid rgba(191, 149, 63, 0.15);
            pointer-events: none;
        }

        .btn-royal:hover {
            border-color: rgba(252, 246, 186, 1);
            color: #fff;
            box-shadow: 0 0 15px rgba(191, 149, 63, 0.6);
        }

        /* --- หน้าจอโหลดทรัพยากร --- */
        .download-screen {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: var(--royal-black);
            z-index: 20;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 40px;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.6s ease-in-out;
        }

        .download-screen.active { opacity: 1; pointer-events: auto; }

        .download-title {
            color: var(--gold-color);
            font-family: 'Cinzel', serif;
            font-size: 0.95rem;
            letter-spacing: 4px;
            margin-bottom: 25px;
            text-transform: uppercase;
        }

        .progress-container {
            width: 80%;
            max-width: 400px;
            height: 6px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(191, 149, 63, 0.25);
            border-radius: 3px;
            position: relative;
            overflow: hidden;
        }

        .progress-bar {
            height: 100%;
            width: 0%;
            background: var(--gold-gradient);
            box-shadow: 0 0 8px #bf953f;
        }

        .progress-text {
            margin-top: 15px;
            color: var(--gold-color);
            font-family: 'Cinzel', serif;
            font-size: 1.1rem;
        }

        /* --- หน้าเรื่องเล่าความฝัน (Story Screen) --- */
        .story-screen {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: #000000;
            z-index: 30;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 40px 30px;
            opacity: 0;
            pointer-events: none;
            transition: opacity 1s ease-in-out;
        }

        .story-screen.active { opacity: 1; pointer-events: auto; }

        .royal-emblem {
            color: var(--gold-color);
            font-size: 2rem;
            margin-bottom: 30px;
            font-family: 'Cinzel', serif;
            letter-spacing: 5px;
        }

        .story-content {
            font-family: 'Sarabun', sans-serif;
            color: #eaeaea;
            font-size: 1.2rem;
            line-height: 2.2;
            text-align: center;
            max-width: 550px;
            margin-bottom: 50px;
            border-top: 1px solid rgba(191, 149, 63, 0.2);
            border-bottom: 1px solid rgba(191, 149, 63, 0.2);
            padding: 40px 10px;
            position: relative;
        }

        .story-content::before { content: "❖"; position: absolute; color: var(--gold-color); left: 50%; transform: translateX(-50%); font-size: 0.8rem; top: -8px; }
        .story-content::after { content: "❖"; position: absolute; color: var(--gold-color); left: 50%; transform: translateX(-50%); font-size: 0.8rem; bottom: -8px; }

        /* --- 👑 หน้าต่างข้อมูลตัวละครแบบอิสระ เต็มตา ไม่ต้องเลื่อน (Character Profile) --- */
        .profile-screen {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: radial-gradient(circle at center, #141419 0%, #030304 100%);
            z-index: 40;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 30px;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.8s ease-in-out;
        }

        .profile-screen.active { opacity: 1; pointer-events: auto; }

        .profile-frame {
            border: 1px solid rgba(191, 149, 63, 0.3);
            width: 100%;
            height: 100%;
            padding: 25px;
            display: flex;
            flex-direction: column;
            background: rgba(0,0,0,0.5);
            justify-content: space-between;
        }

        .royal-title-area {
            text-align: center;
            margin-bottom: 15px;
            border-bottom: 1px solid rgba(191, 149, 63, 0.2);
            padding-bottom: 10px;
        }

        .royal-subtitle {
            font-family: 'Cinzel', serif;
            color: var(--gold-color);
            font-size: 0.8rem;
            letter-spacing: 6px;
            text-transform: uppercase;
        }

        .royal-char-name {
            font-family: 'Cinzel', serif;
            font-size: 1.6rem;
            background: var(--gold-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 600;
            letter-spacing: 2px;
        }

        /* ใช้ Flexbox/Grid อิสระเพื่อแยกฝั่งรูปภาพกับข้อมูลหลัก */
        .profile-main-layout {
            display: flex;
            flex-direction: row;
            gap: 25px;
            align-items: stretch;
            flex-grow: 1;
            height: calc(100% - 140px);
        }

        /* ส่วนแสดงรูปภาพแบบเต็มตัว ไม่โดนตัด และไม่ต้องเลื่อน */
        .char-portrait-container-new {
            flex: 0 0 35%;
            border: 1px solid rgba(191, 149, 63, 0.25);
            background: linear-gradient(to bottom, rgba(20,20,25,0.8), rgba(5,5,7,0.9));
            display: flex;
            justify-content: center;
            align-items: center;
            box-shadow: inset 0 0 20px rgba(0,0,0,0.8);
            padding: 10px;
            height: 100%;
        }

        .char-portrait-new {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
            filter: drop-shadow(0 5px 15px rgba(0,0,0,0.7));
        }

        /* ส่วนแสดงข้อมูลแยกหมวดหมู่สไตล์ UI เกม */
        .char-info-dashboard {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 15px;
            height: 100%;
            overflow: hidden;
        }

        .info-category-box {
            background: rgba(20, 20, 25, 0.6);
            border: 1px solid rgba(191, 149, 63, 0.15);
            padding: 12px 15px;
            border-radius: 4px;
        }

        .category-title {
            font-family: 'Cinzel', serif;
            color: var(--gold-light);
            font-size: 0.85rem;
            letter-spacing: 2px;
            margin-bottom: 8px;
            border-left: 3px solid var(--gold-color);
            padding-left: 8px;
            text-transform: uppercase;
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 8px 20px;
        }

        .info-row-new {
            display: flex;
            justify-content: space-between;
            border-bottom: 1px solid rgba(191, 149, 63, 0.08);
            padding: 4px 0;
            font-size: 0.9rem;
        }

        .info-label-new {
            color: var(--gold-color);
            font-family: 'Cinzel', serif;
            font-size: 0.8rem;
        }

        .info-value-new {
            color: #e5e5e5;
            font-family: 'Sarabun', sans-serif;
            font-weight: 300;
        }

        .bio-box-new {
            flex-grow: 1;
            overflow-y: auto;
            padding-right: 5px;
        }

        .bio-text-new {
            color: #d1d1d1;
            font-family: 'Sarabun', sans-serif;
            font-size: 0.88rem;
            line-height: 1.6;
            text-indent: 20px;
            text-align: justify;
        }

        /* เซ็ตแผงปุ่มควบคุมด้านล่างใหม่แยกฝั่งชัดเจน */
        .profile-action-buttons {
            display: flex;
            gap: 15px;
            margin-top: 15px;
        }
        .btn-profile-action {
            flex: 1;
        }

        /* --- หน้าฉากเกมเพิ่มเติม --- */
        .game-play-screen {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            z-index: 45; opacity: 0; pointer-events: none;
            transition: opacity 1.5s ease-in-out; background: #000;
        }
        .game-play-screen.active { opacity: 1; pointer-events: auto; }

        .game-bg-novel {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background-image: url('https://i.ibb.co/3YMcfwjn/IMG-1859.png');
            background-size: cover; background-position: center; z-index: 1;
        }

        .sunlight-beam {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: radial-gradient(circle at 10% 10%, rgba(255, 230, 160, 0.45) 0%, rgba(0,0,0,0) 70%);
            mix-blend-mode: screen; opacity: 0; z-index: 2;
        }
        .sunlight-beam.shine { animation: sunGlow 3s ease-out forwards; }

        @keyframes sunGlow {
            0% { opacity: 0; }
            40% { opacity: 1; background: #fff; }
            100% { opacity: 0.8; }
        }

        .novel-illustration {
            position: absolute;
            bottom: 15%; left: 50%;
            transform: translateX(-50%) translateY(20px);
            width: 80%; height: 55%;
            background-image: url('https://i.ibb.co/0pDMtWZG/41498-D56-278-D-42-A3-A848-1-B8-FB2421-EB0.png');
            background-size: contain; background-repeat: no-repeat; background-position: center bottom;
            z-index: 3; opacity: 0;
            transition: opacity 2s ease-in-out, transform 2s ease-out;
            filter: drop-shadow(0 10px 15px rgba(0,0,0,0.5));
        }
        .novel-illustration.fade-in { opacity: 1; transform: translateX(-50%) translateY(0); }

        .novel-overlay {
            position: absolute;
            bottom: 0; left: 0; width: 100%; height: 50%;
            background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.4) 60%, rgba(0,0,0,0) 100%);
            z-index: 4;
        }

        .dialogue-box {
            position: absolute;
            bottom: 25px; left: 50%; transform: translateX(-50%);
            width: 90%; min-height: 130px;
            background: rgba(10, 10, 12, 0.95);
            border: 2px solid var(--gold-color);
            border-radius: 4px; padding: 20px; z-index: 5;
            box-shadow: 0 5px 25px rgba(0, 0, 0, 0.95);
            display: flex; flex-direction: column; cursor: pointer;
        }

        .dialogue-name {
            font-family: 'Cinzel', serif; font-size: 1rem; font-weight: 700; letter-spacing: 2px; margin-bottom: 8px;
            background: var(--gold-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        }

        .dialogue-text {
            font-family: 'Sarabun', sans-serif; font-weight: 300; font-size: 0.98rem; line-height: 1.6; color: var(--gold-light);
        }

        .next-indicator { position: absolute; bottom: 8px; right: 12px; color: var(--gold-color); font-size: 0.7rem; animation: bounceIndicator 1.2s infinite alternate; }
        @keyframes bounceIndicator { 0% { transform: translateY(0); opacity: 0.4; } 100% { transform: translateY(-4px); opacity: 1; } }

        /* --- ✨ เอฟเฟกต์ดวงดาวประกายสีขาวระยิบระยับ (White Star Sparkles) --- */
        .sparkle-particle {
            position: absolute;
            pointer-events: none;
            z-index: 100;
            color: #ffffff;
            font-size: 20px;
            line-height: 1;
            text-shadow: 0 0 8px rgba(255, 255, 255, 0.8), 0 0 15px rgba(255, 255, 255, 0.4);
            animation: starParticleFade 0.8s cubic-bezier(0.25, 1, 0.5, 1) forwards;
        }
        @keyframes starParticleFade {
            0% {
                transform: translate(0, 0) scale(0.2) rotate(0deg);
                opacity: 0;
            }
            15% {
                opacity: 1;
            }
            100% {
                transform: translate(var(--x), var(--y)) scale(1.2) rotate(180deg);
                opacity: 0;
            }
        }

        /* --- ระบบคำแนะนำลอยแบบเดิม --- */
        .overlay-layer {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.9); z-index: 50;
            display: flex; justify-content: center; align-items: center;
            opacity: 0; pointer-events: none; transition: opacity 0.5s ease;
        }
        .overlay-layer.active { opacity: 1; pointer-events: auto; }

        .countdown-number {
            font-size: 5rem; color: var(--gold-color); font-family: 'Cinzel', serif;
            text-shadow: 0 0 20px rgba(191,149,63,0.6); display: none;
        }

        .info-box {
            width: 85%; max-width: 450px; background: rgba(10, 10, 12, 0.98); border: 1px solid var(--gold-color);
            padding: 40px 25px; text-align: center; position: relative;
            transform: translateY(40px); opacity: 0; transition: transform 1.2s cubic-bezier(0.1, 0.8, 0.3, 1), opacity 1s ease;
            display: none; box-shadow: 0 10px 35px rgba(0,0,0,0.9);
        }
        .info-box.float-up { display: block; opacity: 1; transform: translateY(0); }

        .info-text { color: #fcf6ba; font-family: 'Sarabun', sans-serif; font-weight: 300; line-height: 2.0; font-size: 1.05rem; }

        .close-btn {
            position: absolute; top: -15px; right: -15px; width: 34px; height: 34px; background: #000;
            border: 1px solid var(--gold-color); color: var(--gold-color); border-radius: 50%; cursor: pointer;
            font-family: 'Cinzel', serif; font-size: 1.1rem; display: flex; justify-content: center; align-items: center;
            opacity: 0; transition: opacity 0.5s ease;
        }

        /* ==================== 👑 ฉากเต้นรำและตอนจบของฝันดีไซน์พิเศษ ==================== */
        .ending-screen {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            z-index: 60; opacity: 0; pointer-events: none;
            transition: opacity 2s ease-in-out;
            background: radial-gradient(circle at center, #110e1a 0%, #030205 100%);
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            align-items: center;
            padding: 40px 20px;
        }
        .ending-screen.active { opacity: 1; pointer-events: auto; }

        /* ตัวแสดงผลรูปภาพเต้นรำแบบซูมช้าๆ อบอุ่น */
        .ending-image-container {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            z-index: 1;
            overflow: hidden;
        }

        .ending-image {
            width: 100%; height: 100%;
            object-fit: cover;
            background-position: center top; /* 🌟 ปรับให้จุดศูนย์กลางของภาพเริ่มต้นจากด้านบน เพื่อให้เห็นใบหน้าชัดเจน */
            opacity: 0;
            transform: scale(1.15); /* 🌟 เพิ่มสเกลเริ่มต้นเล็กน้อยเพื่อเตรียมซูมรับใบหน้า */
            transition: opacity 3s ease-in-out, transform 15s cubic-bezier(0.1, 0.8, 0.3, 1);
        }
        .ending-screen.active .ending-image {
            opacity: 0.85;
            transform: scale(1.08) translateY(0px); /* 🌟 ซูมค้างในองศาที่เน้นใบหน้าของทั้งคู่ประมาณครึ่งบน */
        }

        /* เลเยอร์ซ้อนกันแสงแข็งและเพิ่มความนุ่มนวล */
        .ending-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(10,8,15,0.4) 50%, rgba(5,4,8,0.95) 95%);
            z-index: 2;
            pointer-events: none;
        }

        /* เอฟเฟกต์แสงวาบสีขาวตอนเปลี่ยนผ่านฉาก (White Flash Effect) */
        .white-flash {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: #ffffff;
            z-index: 99;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.6s ease-out;
        }
        .white-flash.active {
            opacity: 1;
            transition: none;
        }

        /* ส่วนกล่องข้อความบรรยายตอนจบความฝัน */
        .ending-dialogue-box {
            width: 90%;
            max-width: 600px;
            background: rgba(10, 8, 15, 0.9);
            border: 1px solid rgba(223, 186, 107, 0.5);
            box-shadow: 0 0 25px rgba(223, 186, 107, 0.15), inset 0 0 15px rgba(255, 255, 255, 0.05);
            padding: 25px 30px;
            border-radius: 4px;
            z-index: 3;
            text-align: center;
            transform: translateY(20px);
            opacity: 0;
            transition: transform 2s cubic-bezier(0.1, 0.8, 0.3, 1), opacity 2s ease;
        }
        .ending-screen.active .ending-dialogue-box {
            opacity: 1;
            transform: translateY(0);
        }

        .ending-title {
            font-family: 'Cinzel', serif;
